# OpenMeteo API (free, no key required)
# Override location if needed
FARM_LATITUDE=12.37
FARM_LONGITUDE=-1.52
FARM_NAME=Ferme Demo Ouagadougou

# Tarifs SONABEL (FCFA/kWh) - alignes sur agriwater-optimizer original
